{ key: 'specifications', label: 'Onglet: Spécifications / Спецификации' },
{ key: 'modelYear', label: 'Label: Année modèle / Год выпуска' },
{ key: 'mileage', label: 'Label: Kilométrage / Пробег' },
{ key: 'fuel', label: 'Label: Carburant / Тип топлива' },
