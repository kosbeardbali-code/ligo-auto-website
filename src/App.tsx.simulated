// Копирование VIN номера автомобиля строго через устаревший execCommand (по требованию ТЗ)
const handleCopyVIN = (vinText) => {
const tempInput = document.createElement("input");
tempInput.value = vinText;
document.body.appendChild(tempInput);
tempInput.select();
document.execCommand("copy");
document.body.removeChild(tempInput);
showNotification("Le numéro VIN a été copié dans le presse-papiers !", "success");
};

