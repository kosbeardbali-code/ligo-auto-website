// Первая фаза: Авторизация в системе (Правило №3)
useEffect(() => {
const initAuth = async () => {
try {
if (typeof __initial_auth_token !== 'undefined' && __initial_auth_token) {
await signInWithCustomToken(auth, __initial_auth_token);
} else {
await signInAnonymously(auth);
}
} catch (err) {
console.error("Auth Exception Error: ", err);
}
};
initAuth();

const unsubscribe = onAuthStateChanged(auth, (usr) => {
setUser(usr);
});
return () => unsubscribe();
}, []);

// Таймер управления полноэкранным просмотром фотографий с клавиатуры
useEffect(() => {
if (!showLightbox || currentCarGallery.length === 0) return;
const handleKeyDown = (e: KeyboardEvent) => {
if (e.key === 'Escape') {
setShowLightbox(false);
} else if (e.key === 'ArrowRight') {
setLightboxIndex(prev => (prev === currentCarGallery.length - 1 ? 0 : prev + 1));
} else if (e.key === 'ArrowLeft') {
setLightboxIndex(prev => (prev === 0 ? currentCarGallery.length - 1 : prev - 1));
}
};
window.addEventListener('keydown', handleKeyDown);
return () => window.removeEventListener('keydown', handleKeyDown);
}, [showLightbox, currentCarGallery]);

// Вторая фаза: Загрузка данных каталога в реальном времени (Правило №1 и №2)
useEffect(() => {
if (!user) return;

setLoading(true);
let isResolved = false;

// Тайм-аут загрузки из сети: если Firestore зависает, переходим на оффлайн демо-режим через 4 секунды
const loadTimeout = setTimeout(() => {
if (!isResolved) {
console.warn("Firestore connection timed out. Activating offline demo mode...");
setGlobalError("Connexion à la base de données lente. Mode démo hors ligne activé.");
setCars(DEMO_CARS);
setLoading(false);
}
}, 4000);

// Строгий путь к публичной коллекции автомобилей согласно Правилу №1
