                          <div className="text-xs font-mono font-bold text-neutral-900 dark:text-white tracking-wider uppercase mt-0.5">{selectedCar.vin}</div>
                        </div>
                        <button 
                          onClick={() => handleCopyVIN(selectedCar.vin)}
                          className="text-[10px] font-bold text-[#D4AF37] hover:underline"
>
{t('copy')}
