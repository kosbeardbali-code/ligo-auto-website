// Загрузка запросов от клиентов в реальном времени (для администратора)
useEffect(() => {
if (!isAdmin) return;

const inquiriesCollectionRef = collection(db, 'artifacts', appId, 'public', 'data', 'inquiries');
const q = query(inquiriesCollectionRef);

const unsubscribe = onSnapshot(q, (snapshot) => {
const list = [];
snapshot.forEach((doc) => {
list.push({ id: doc.id, ...doc.data() });
});
// Сортировка по времени создания
list.sort((a, b) => new Date(b.createdAt || 0).getTime() - new Date(a.createdAt || 0).getTime());
setInquiries(list);
}, (err) => {
// Сортировка по времени создания
list.sort((a, b) => new Date(b.createdAt || 0).getTime() - new Date(a.createdAt || 0).getTime());
setInquiries(list);
}, (err) => {
console.warn('Firestore inquiries subscription error:', err);
});

return () => unsubscribe();
}, [isAdmin, appId]);

// Загрузка CMS настроек сайта в реальном времени
useEffect(() => {
const settingsDocRef = doc(db, 'artifacts', appId, 'public', 'data', 'settings', 'site');
const unsubscribe = onSnapshot(settingsDocRef, (docSnap) => {
if (docSnap.exists()) {
setSiteSettings(prev => ({ ...prev, ...docSnap.data() }));
}
}, (err) => {
console.warn('Firestore settings subscription error (using default config):', err);
});
return () => unsubscribe();
}, [appId]);

