<button
type="submit"
className="px-8 py-3 rounded-xl bg-[#D4AF37] hover:bg-[#D4AF37]/90 text-neutral-950 font-bold text-xs uppercase tracking-wider transition-all shadow-lg"
>
Enregistrer les modifications
</button>
</div>
</form>
);
};

