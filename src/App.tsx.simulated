const handleDeleteInquiry = async (inquiryId) => {
try {
const isMockFirebase = !firebaseConfig || 
!firebaseConfig.apiKey || 
firebaseConfig.apiKey.includes('mock') || 
firebaseConfig.projectId === 'mock-project';

if (isMockFirebase) {
throw new Error("Mock Firebase detected");
}

const docRef = doc(db, 'artifacts', appId, 'public', 'data', 'inquiries', inquiryId);
await withTimeout(deleteDoc(docRef), 3000);
showNotification("La demande a été supprimée.", "success");
} catch (err) {
console.error("Error deleting inquiry: ", err);
setInquiries(prev => prev.filter(inq => inq.id !== inquiryId));
showNotification("Demande supprimée (mode hors ligne).", "info");
}
};

