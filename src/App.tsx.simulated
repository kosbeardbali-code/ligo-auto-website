if (formErrors.brand) setFormErrors(prev => ({ ...prev, brand: false }));
}} 
className={`w-full bg-neutral-50 border rounded-xl py-2.5 px-4 text-neutral-900 placeholder-neutral-400 focus:outline-none transition-all ${
