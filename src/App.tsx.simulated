],
forms: [
{ key: 'financing', label: 'Onglet: Financement / Кредит и Лизинг' },
{ key: 'procedures', label: 'Onglet: Démarches / Оформление документов' },
{ key: 'simulatedLoa', label: 'Titre: Mensualité LOA / Оценочный лизинг' },
{ key: 'apport', label: 'Label: Apport / Первоначальный взнос' },
{ key: 'duration', label: 'Label: Durée / Срок лизинга' },
{ key: 'months', label: 'Suffixe: Mois / мес' },
{ key: 'monthlyPayment', label: 'Label: Mensualité / Ежемесячный платеж' },
{ key: 'applyCG', label: 'Bouton: Demande CG / Подать заявку' },
{ key: 'testDrive', label: 'Onglet: Essai / Тест-драйв' },
{ key: 'bookTestDrive', label: 'Titre: Planifier essai / Записаться' },
{ key: 'clientInfo', label: 'Titre: Infos titulaire / Данные владельца' },
{ key: 'fullName', label: 'Label: Nom complet / ФИО' },
{ key: 'email', label: 'Label: E-mail / Эл. почта' },
{ key: 'phone', label: 'Label: Téléphone / Телефон' },
{ key: 'address', label: 'Label: Adresse / Почтовый адрес' },
{ key: 'tradeInQuestion', label: 'Question: Reprise ? / Хотите в трейд-ин?' },
{ key: 'tradeInInfo', label: 'Titre: Détails reprise / Детали авто' },
{ key: 'tradeInBrandModel', label: 'Label: Marque & Modèle / Марка и Модель' },
{ key: 'tradeInYear', label: 'Label: Année / Год выпуска' },
{ key: 'tradeInKm', label: 'Label: Kilométrage / Пробег' },
{ key: 'tradeInCondition', label: 'Label: État / Состояние' },
{ key: 'selectDateTime', label: 'Label: Date & Heure / Дата и время' },
{ key: 'preferredDate', label: 'Label: Date / Желаемая дата' },
{ key: 'preferredTime', label: 'Label: Heure / Желаемое время' },
{ key: 'specialRequest', label: 'Label: Demande / Пожелания' },
{ key: 'sendRequest', label: 'Bouton: Envoyer / Отправить запрос' },
{ key: 'formSuccess', label: 'Message: Succès / Успешно отправлено' },
{ key: 'formError', label: 'Message: Erreur / Ошибка отправки' }
]
};

const activeKeys = categories[translationActiveTab as keyof typeof categories] || [];

return activeKeys.map((item) => (
<div key={item.key} className="space-y-1 animate-fadeIn">
<label className="text-neutral-600 dark:text-neutral-400 font-semibold block">{item.label}</label>
<input 
type="text" 
value={siteSettings?.translations?.[translationEditLang]?.[item.key] !== undefined 
? siteSettings.translations[translationEditLang][item.key] 
: (translations[translationEditLang as 'fr'|'ru']?.[item.key as keyof typeof translations['fr']] || '')} 
onChange={(e) => {
const updatedTranslations = {
...siteSettings.translations,
[translationEditLang]: {
...(siteSettings.translations?.[translationEditLang] || {}),
[item.key]: e.target.value
}
};
setSiteSettings({
...siteSettings,
translations: updatedTranslations
});
}} 
className="w-full bg-white dark:bg-[#0D0D0D] border border-neutral-200 dark:border-neutral-800 focus:border-[#D4AF37] rounded-xl py-2 px-3 text-neutral-900 dark:text-white focus:outline-none" 
/>
</div>
));
})()}
</div>
