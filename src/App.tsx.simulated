                    onClick={() => setTranslationEditLang('fr')}
                    className={`px-3 py-1.5 text-xs font-bold rounded-lg transition-all ${translationEditLang === 'fr' ? 'bg-[#D4AF37] text-neutral-950 shadow-sm' : 'bg-neutral-100 dark:bg-neutral-900 text-neutral-600 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white'}`}
                  >
                    FR
