<input type="text" placeholder="Label" value={siteSettings.stat3Label || ''} onChange={(e) => setSiteSettings({...siteSettings, stat3Label: e.target.value})} className="w-full bg-white dark:bg-[#0D0D0D] border border-neutral-200 dark:border-neutral-800 focus:border-[#D4AF37] rounded-xl py-1 px-2 text-[10px] text-neutral-700 dark:text-neutral-300 focus:outline-none mt-1" />
