const renderCarDetails = () => {
if (!selectedCar) return null;

// Calcul de la LOA
const residual = selectedCar.price * 0.45;
const financed = selectedCar.price - loanApport - residual;
const base = financed / loanDuration;
const interest = (selectedCar.price - loanApport) * 0.04 / 12;
const monthlyLOA = Math.max(50, Math.round(base + interest));

// Calcul du malus écologique
const malus = selectedCar.hp < 150 ? 0 : (selectedCar.hp <= 250 ? 950 : (selectedCar.hp <= 450 ? 4500 : 15000));

// Images de la galerie
const galleryImages = selectedCar.images && selectedCar.images.length > 0
? selectedCar.images
: [
selectedCar.image || 'https://images.unsplash.com/photo-1614162692292-7ac56d7f7f1e?auto=format&fit=crop&q=80&w=1200',
selectedCar.image2 || "https://images.unsplash.com/photo-1503376780353-7e6692767b70?auto=format&fit=crop&q=80&w=1200",
selectedCar.image3 || "https://images.unsplash.com/photo-1611566141071-1a3b96d8373a?auto=format&fit=crop&q=80&w=1200"
].filter(Boolean);

const prefilledText = `Bonjour, je vous contacte concernant la ${selectedCar.brand} ${selectedCar.model} affichée à ${selectedCar.price.toLocaleString('fr-FR')} € sur votre site...`;

// Soumettre le financement
const handleFinanceSubmit = (e) => {
e.preventDefault();
handleInquirySubmit({
type: "Demande de financement (LOA)",
carBrand: selectedCar.brand,
carModel: selectedCar.model,
carPrice: selectedCar.price,
clientName: user?.email || "Visiteur",
message: `Simulateur LOA: Apport de ${loanApport.toLocaleString()} €, Durée de ${loanDuration} mois. Mensualité estimée de ${monthlyLOA} € / mois.`
});
};

// Soumettre la carte grise / reprise
const handleCarteGriseSubmit = (e) => {
e.preventDefault();
if (!cgForm.name || !cgForm.email || !cgForm.phone || !cgForm.address) {
showNotification("Veuillez remplir tous les champs du dossier.", "error");
return;
}
handleInquirySubmit({
type: "Carte Grise & Immatriculation",
carBrand: selectedCar.brand,
carModel: selectedCar.model,
carPrice: selectedCar.price,
clientName: cgForm.name,
clientEmail: cgForm.email,
clientPhone: cgForm.phone,
clientAddress: cgForm.address,
hasTradeIn: cgForm.hasTradeIn,
tradeInDetails: cgForm.hasTradeIn ? `${cgForm.tradeInBrandModel} (${cgForm.tradeInYear}) - ${cgForm.tradeInKm} km - État: ${cgForm.tradeInCondition}` : ""
});
};

// Soumettre la demande d'essai
const handleTestDriveSubmit = (e) => {
e.preventDefault();
if (!testDriveForm.name || !testDriveForm.email || !testDriveForm.phone || !testDriveForm.date || !testDriveForm.time) {
showNotification("Veuillez remplir toutes les informations pour le rendez-vous.", "error");
return;
}
handleInquirySubmit({
type: "Demande d'essai / RDV",
carBrand: selectedCar.brand,
carModel: selectedCar.model,
carPrice: selectedCar.price,
clientName: testDriveForm.name,
clientEmail: testDriveForm.email,
clientPhone: testDriveForm.phone,
preferredDate: testDriveForm.date,
preferredTime: testDriveForm.time,
message: testDriveForm.message
});
};

// Soumettre la carte grise / reprise
