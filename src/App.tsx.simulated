// Save CMS settings to Firestore
const handleSaveSettings = async (e: React.FormEvent) => {
e.preventDefault();
try {
const isMockFirebase = !firebaseConfig || 
!firebaseConfig.apiKey || 
firebaseConfig.apiKey.includes('mock') || 
firebaseConfig.projectId === 'mock-project';

if (isMockFirebase) {
throw new Error("Mock Firebase detected");
}

const settingsDocRef = doc(db, 'artifacts', appId, 'public', 'data', 'settings', 'site');
await withTimeout(setDoc(settingsDocRef, siteSettings), 3000);
showNotification(lang === 'ru' ? "Настройки успешно сохранены!" : "Paramètres enregistrés !", "success");
} catch (err) {
console.error("Error saving settings: ", err);
showNotification(lang === 'ru' ? "Настройки сохранены локально." : "Paramètres enregistrés (mode hors ligne).", "success");
}
};

const renderAdminSettings = () => {
return (
<form onSubmit={handleSaveSettings} className="space-y-8 bg-white dark:bg-[#121214] border border-neutral-200 dark:border-neutral-900 rounded-2xl p-8 shadow-xl animate-fadeIn mb-12">
<div>
<h3 className="text-xl text-neutral-900 dark:text-white font-serif tracking-wide mb-2">Configuration Globale du Site</h3>
<p className="text-neutral-600 dark:text-neutral-400 dark:text-neutral-400 text-sm">Modifiez tous les textes, titres, statistiques et coordonnées de contact affichés publiquement.</p>
<h4 className="text-xs uppercase tracking-widest text-[#D4AF37] font-bold pb-2 border-b border-neutral-200 dark:border-neutral-900">Section Véhicules Phares</h4>
<div className="space-y-3 text-xs">
<div className="space-y-1">
<label className="text-neutral-600 dark:text-neutral-400 font-semibold block">Surtitre (ex: Sélection exclusive)</label>
<input type="text" value={siteSettings.featuredCategory || ''} onChange={(e) => setSiteSettings({...siteSettings, featuredCategory: e.target.value})} className="w-full bg-white dark:bg-[#0D0D0D] border border-neutral-200 dark:border-neutral-800 focus:border-[#D4AF37] rounded-xl py-2.5 px-4 text-neutral-900 dark:text-white focus:outline-none" />
</div>
<div className="space-y-1">
<label className="text-neutral-600 dark:text-neutral-400 font-semibold block">Titre de la section</label>
}

const settingsDocRef = doc(db, 'artifacts', appId, 'public', 'data', 'settings', 'site');
await withTimeout(setDoc(settingsDocRef, siteSettings), 3000);
showNotification(lang === 'ru' ? "Настройки успешно сохранены!" : "Paramètres enregistrés !", "success");
} catch (err) {
console.error("Error saving settings: ", err);
showNotification(lang === 'ru' ? "Настройки сохранены локально." : "Paramètres enregistrés (mode hors ligne).", "success");
}
};

const renderAdminSettings = () => {
return (
<form onSubmit={handleSaveSettings} className="space-y-8 bg-white dark:bg-[#121214] border border-neutral-200 dark:border-neutral-900 rounded-2xl p-8 shadow-xl animate-fadeIn mb-12">
<div>
<h3 className="text-xl text-neutral-900 dark:text-white font-serif tracking-wide mb-2">Configuration Globale du Site</h3>
<p className="text-neutral-600 dark:text-neutral-400 dark:text-neutral-400 text-sm">Modifiez tous les textes, titres, statistiques et coordonnées de contact affichés publiquement.</p>
</div>

<div className="grid grid-cols-1 lg:grid-cols-2 gap-8">
{/* Левая колонка: Баннер и Фичед Секция */}
<div className="space-y-8 lg:border-r lg:border-neutral-900 lg:pr-8">
{/* Bannière */}
<div className="space-y-4">
<h4 className="text-xs uppercase tracking-widest text-[#D4AF37] font-bold pb-2 border-b border-neutral-200 dark:border-neutral-900">Bannière d'accueil</h4>
<div className="space-y-3 text-xs">
<div className="space-y-1">
<label className="text-neutral-600 dark:text-neutral-400 font-semibold block">Titre principal</label>
<input type="text" value={siteSettings.bannerTitle} onChange={(e) => setSiteSettings({...siteSettings, bannerTitle: e.target.value})} className="w-full bg-white dark:bg-[#0D0D0D] border border-neutral-200 dark:border-neutral-800 focus:border-[#D4AF37] rounded-xl py-2.5 px-4 text-neutral-900 dark:text-white focus:outline-none" />
