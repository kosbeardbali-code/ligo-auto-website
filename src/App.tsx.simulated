<input type="text" value={siteSettings.bannerSubtitle} onChange={(e) => setSiteSettings({...siteSettings, bannerSubtitle: e.target.value})} className="w-full bg-white dark:bg-[#0D0D0D] border border-neutral-200 dark:border-neutral-800 focus:border-[#D4AF37] rounded-xl py-2.5 px-4 text-neutral-900 dark:text-white focus:outline-none" />
